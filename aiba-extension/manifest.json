{
  "manifest_version": 3,
  "name": "Ai-Ba Tools",
  "version": "0.6.0",
  "description": "Ai-Ba 会議ツール — 仮想カメラ + リアルタイム文字起こし（話者名対応）",
  "permissions": ["tabCapture", "offscreen", "scripting", "storage"],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://*.zoom.us/*",
    "https://teams.microsoft.com/*",
    "https://*.lambda-url.ap-northeast-1.on.aws/*",
    "http://localhost:5173/*",
    "https://wpripgjmae.execute-api.ap-northeast-1.amazonaws.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*",
        "https://*.zoom.us/*",
        "https://teams.microsoft.com/*"
      ],
      "js": ["toolbar.js", "tool-camera.js", "tool-noter.js"],
      "css": ["toolbar.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["meet-rtc-hook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["meet-captions.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://teams.microsoft.com/*", "https://*.teams.microsoft.com/*", "https://teams.live.com/*"],
      "js": ["teams-captions.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://*.zoom.us/*"],
      "js": ["zoom-captions.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["http://localhost:5173/*"],
      "js": ["app-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Ai-Ba Tools",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "matches": ["https://meet.google.com/*"],
      "resources": ["meet-rtc-hook.js"]
    },
    {
      "matches": ["https://teams.microsoft.com/*", "https://*.teams.microsoft.com/*", "https://teams.live.com/*"],
      "resources": ["teams-rtc-hook.js"]
    },
    {
      "matches": ["https://*.zoom.us/*"],
      "resources": ["zoom-hook.js"]
    }
  ],
  "icons": {}
}
